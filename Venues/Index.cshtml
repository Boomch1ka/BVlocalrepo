@model IEnumerable<B_V__CLDV7111_.Models.Venue>

<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Venues</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="p-4">
    <div class="container">
        <h1>Venues</h1>
        <p><a class="btn btn-primary" href="/Venues/Create">Create new</a> <a class="btn btn-secondary" href="/Identity/Account/Register">Register</a> <a class="btn btn-secondary" href="/Identity/Account/Login">Login</a></p>
        <div class="row">
            @foreach(var v in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <img src="@v.ImageUrl" class="card-img-top" alt="@v.Name" />
                        <div class="card-body">
                            <h5 class="card-title">@v.Name</h5>
                            <p class="card-text">@v.Address</p>
                            <a class="btn btn-sm btn-outline-primary" href="/Venues/Details/@v.Id">Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</body>
</html>
